# Humblebee environment variables
# Copy to .env and edit as needed

# Database path (relative to backend/)
# DB_PATH=../storage/humblebee.duckdb

# Password protection (optional)
# AUTH_ENABLED=true
# ADMIN_PASSWORD=your-secret-password
# SECURE_COOKIES=true  # set to true when serving over HTTPS
# AUTH_SECRET=  # 64 hex chars; generate with: python -c "import secrets; print(secrets.token_hex(32))"
